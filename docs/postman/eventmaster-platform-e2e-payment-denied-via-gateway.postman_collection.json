{
  "info": {
    "_postman_id": "4cb0e9d4-c0ee-47a0-8ab7-c84f3ef80f4d",
    "name": "EventMaster - Platform E2E Payment Denied via Gateway",
    "description": "Collection end-to-end dedicada ao cenário de pagamento negado via API Gateway. O fluxo cria eventos e pedidos até encontrar um orderId terminando em 6 ou 9, então valida a finalização em CANCELADO/Disponivel.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "jwt",
      "value": "",
      "type": "string"
    },
    {
      "key": "runId",
      "value": "",
      "type": "string"
    },
    {
      "key": "eventSequence",
      "value": "0",
      "type": "string"
    },
    {
      "key": "eventId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "eventName",
      "value": "",
      "type": "string"
    },
    {
      "key": "attendeeOneName",
      "value": "",
      "type": "string"
    },
    {
      "key": "attendeeTwoName",
      "value": "",
      "type": "string"
    },
    {
      "key": "deniedOrderAttempts",
      "value": "0",
      "type": "string"
    },
    {
      "key": "orderCreateAttempts",
      "value": "0",
      "type": "string"
    },
    {
      "key": "ticketPollAttempts",
      "value": "0",
      "type": "string"
    },
    {
      "key": "expectedPaymentOutcome",
      "value": "PAGAMENTO_NEGADO",
      "type": "string"
    },
    {
      "key": "expectedOrderOutcome",
      "value": "CANCELADO",
      "type": "string"
    },
    {
      "key": "expectedTicketStatus",
      "value": "Disponivel",
      "type": "string"
    },
    {
      "key": "login",
      "value": "admin@eventmaster.com",
      "type": "string"
    },
    {
      "key": "senha",
      "value": "Senha@123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - Login via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{login}}\",\n  \"senha\": \"{{senha}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Obtém um JWT via gateway e inicializa as variáveis dinâmicas do cenário de pagamento negado."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no login', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('JWT retornado no login', function () {",
              "    pm.expect(json.jwt).to.be.a('string').and.not.empty;",
              "});",
              "",
              "const runId = String(Date.now());",
              "pm.environment.set('jwt', json.jwt);",
              "pm.environment.set('runId', runId);",
              "pm.environment.set('eventSequence', '0');",
              "pm.environment.set('deniedOrderAttempts', '0');",
              "pm.environment.set('orderCreateAttempts', '0');",
              "pm.environment.set('ticketPollAttempts', '0');",
              "pm.environment.set('expectedPaymentOutcome', 'PAGAMENTO_NEGADO');",
              "pm.environment.set('expectedOrderOutcome', 'CANCELADO');",
              "pm.environment.set('expectedTicketStatus', 'Disponivel');",
              "pm.environment.unset('eventId');",
              "pm.environment.unset('orderId');",
              "pm.environment.unset('eventName');",
              "pm.environment.unset('attendeeOneName');",
              "pm.environment.unset('attendeeTwoName');"
            ]
          }
        }
      ]
    },
    {
      "name": "2 - Criar evento candidato via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"{{eventName}}\",\n  \"data\": \"15/12/2026\",\n  \"hora\": \"20:00:00\",\n  \"local\": \"Teatro Central\",\n  \"capacidade\": 1500.0,\n  \"precoBase\": 89.90\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/events",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events"
          ]
        },
        "description": "Cria um evento candidato para tentar encontrar um pedido cujo orderId termine em 6 ou 9."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = pm.environment.get('runId') || String(Date.now());",
              "const nextSequence = Number(pm.environment.get('eventSequence') || '0') + 1;",
              "pm.environment.set('runId', runId);",
              "pm.environment.set('eventSequence', String(nextSequence));",
              "pm.environment.set('eventName', 'Show da ADA - E2E Negado ' + runId + ' #' + nextSequence);",
              "pm.environment.set('attendeeOneName', 'Portador Negado A ' + runId + ' #' + nextSequence);",
              "pm.environment.set('attendeeTwoName', 'Portador Negado B ' + runId + ' #' + nextSequence);",
              "pm.environment.set('orderCreateAttempts', '0');",
              "pm.environment.set('ticketPollAttempts', '0');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201 ao criar evento candidato', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Evento candidato criado com id e precoBase corretos', function () {",
              "    pm.expect(json.id).to.exist;",
              "    pm.expect(json.nome).to.eql(pm.environment.get('eventName'));",
              "    pm.expect(Number(json.precoBase)).to.eql(89.9);",
              "});",
              "",
              "pm.environment.set('eventId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "3 - Buscar evento candidato via Gateway",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/events/{{eventId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "events",
            "{{eventId}}"
          ]
        },
        "description": "Confirma o evento candidato antes de disparar o pedido."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 ao buscar evento candidato', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Evento retornado corresponde ao candidato criado', function () {",
              "    pm.expect(String(json.id)).to.eql(String(pm.environment.get('eventId')));",
              "    pm.expect(json.nome).to.eql(pm.environment.get('eventName'));",
              "    pm.expect(Number(json.precoBase)).to.eql(89.9);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4 - Criar pedido candidato via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"eventId\": {{eventId}},\n  \"formaPagamento\": \"PIX\",\n  \"itens\": [\n    {\n      \"nomePortador\": \"{{attendeeOneName}}\",\n      \"cpfPortador\": \"123.456.789-00\",\n      \"tipoIngresso\": \"INTEIRA\"\n    },\n    {\n      \"nomePortador\": \"{{attendeeTwoName}}\",\n      \"cpfPortador\": \"987.654.321-00\",\n      \"tipoIngresso\": \"MEIA\"\n    }\n  ]\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        },
        "description": "Cria pedidos candidatos até encontrar um orderId terminando em 6 ou 9. Em caso de estoque ainda não propagado para o Redis, o request tenta novamente automaticamente."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const inventoryAttempts = Number(pm.environment.get('orderCreateAttempts') || '0');",
              "if (pm.response.code === 409 && inventoryAttempts < 5) {",
              "    pm.environment.set('orderCreateAttempts', String(inventoryAttempts + 1));",
              "    postman.setNextRequest(pm.info.requestName);",
              "    return;",
              "}",
              "",
              "pm.test('Status 201 ao criar pedido candidato', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "const orderId = Number(json.id);",
              "const lastDigit = Math.abs(orderId % 10);",
              "const isDenied = lastDigit === 6 || lastDigit === 9;",
              "pm.test('Pedido criado com resumo correto', function () {",
              "    pm.expect(json.id).to.exist;",
              "    pm.expect(Number(json.valorTotal)).to.eql(134.85);",
              "    pm.expect(json.status).to.eql('REALIZADO');",
              "});",
              "",
              "if (!isDenied) {",
              "    const deniedAttempts = Number(pm.environment.get('deniedOrderAttempts') || '0') + 1;",
              "    pm.environment.set('deniedOrderAttempts', String(deniedAttempts));",
              "    pm.environment.set('orderCreateAttempts', '0');",
              "    pm.environment.set('ticketPollAttempts', '0');",
              "    pm.environment.unset('eventId');",
              "    pm.environment.unset('orderId');",
              "    if (deniedAttempts < 15) {",
              "        postman.setNextRequest('2 - Criar evento candidato via Gateway');",
              "        return;",
              "    }",
              "    pm.test('Foi possível encontrar um orderId terminando em 6 ou 9', function () {",
              "        pm.expect.fail('Nenhum orderId terminando em 6 ou 9 foi encontrado após ' + deniedAttempts + ' pedidos candidatos.');",
              "    });",
              "    return;",
              "}",
              "",
              "pm.test('Pedido negado identificado pelo orderId', function () {",
              "    pm.expect([6, 9]).to.include(lastDigit);",
              "});",
              "",
              "pm.environment.set('orderId', json.id);",
              "pm.environment.set('orderCreateAttempts', '0');",
              "pm.environment.set('ticketPollAttempts', '0');"
            ]
          }
        }
      ]
    },
    {
      "name": "5 - Listar ingressos cancelados via Gateway",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets"
          ]
        },
        "description": "Lista os ingressos via gateway e aguarda o estado final do cenário de pagamento negado. Os dois ingressos do pedido vencedor devem chegar a Disponivel."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 ao listar ingressos', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const tickets = pm.response.json();",
              "const eventName = pm.environment.get('eventName');",
              "const attendeeOne = pm.environment.get('attendeeOneName');",
              "const attendeeTwo = pm.environment.get('attendeeTwoName');",
              "const expectedTicketStatus = pm.environment.get('expectedTicketStatus');",
              "const currentAttempts = Number(pm.environment.get('ticketPollAttempts') || '0');",
              "",
              "const relevant = tickets.filter(ticket =>",
              "    ticket.evento === eventName",
              "    && [attendeeOne, attendeeTwo].includes(ticket.nomeParticipante)",
              ");",
              "",
              "const finalStateReached = relevant.length === 2 && relevant.every(ticket => ticket.situacao === expectedTicketStatus);",
              "if (!finalStateReached && currentAttempts < 12) {",
              "    pm.environment.set('ticketPollAttempts', String(currentAttempts + 1));",
              "    postman.setNextRequest(pm.info.requestName);",
              "    return;",
              "}",
              "",
              "pm.test('Dois ingressos do pedido negado foram encontrados', function () {",
              "    pm.expect(relevant.length).to.eql(2);",
              "});",
              "",
              "const byName = {};",
              "relevant.forEach(ticket => { byName[ticket.nomeParticipante] = ticket; });",
              "",
              "pm.test('Ingresso inteira finalizado como disponível', function () {",
              "    pm.expect(byName[attendeeOne]).to.exist;",
              "    pm.expect(byName[attendeeOne].tipoIngresso).to.eql('Inteira');",
              "    pm.expect(byName[attendeeOne].situacao).to.eql('Disponivel');",
              "    pm.expect(Number(byName[attendeeOne].valor)).to.eql(89.9);",
              "});",
              "",
              "pm.test('Ingresso meia finalizado como disponível', function () {",
              "    pm.expect(byName[attendeeTwo]).to.exist;",
              "    pm.expect(byName[attendeeTwo].tipoIngresso).to.eql('Meia');",
              "    pm.expect(byName[attendeeTwo].situacao).to.eql('Disponivel');",
              "    pm.expect(Number(byName[attendeeTwo].valor)).to.eql(44.95);",
              "});",
              "",
              "pm.environment.set('ticketPollAttempts', '0');"
            ]
          }
        }
      ]
    },
    {
      "name": "6 - Logout via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        },
        "description": "Encerra a sessão JWT ao final do cenário de pagamento negado."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no logout', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.environment.unset('jwt');",
              "pm.environment.set('orderCreateAttempts', '0');",
              "pm.environment.set('ticketPollAttempts', '0');"
            ]
          }
        }
      ]
    }
  ]
}

