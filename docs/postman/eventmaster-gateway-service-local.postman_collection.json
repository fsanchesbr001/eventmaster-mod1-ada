{
  "info": {
    "_postman_id": "2ca5f1fd-0702-4ad2-a4f6-22f53dd03ef1",
    "name": "EventMaster - Gateway Service Local",
    "description": "Collection para validar o gateway-service, seu healthcheck, rotas expostas e o acesso aos OpenAPI proxied dos serviços downstream.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "jwt",
      "value": "",
      "type": "string"
    },
    {
      "key": "login",
      "value": "admin@eventmaster.com",
      "type": "string"
    },
    {
      "key": "senha",
      "value": "Senha@123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - Healthcheck do Gateway",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/actuator/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "health"
          ]
        },
        "description": "Valida que o gateway-service está de pé e respondendo no endpoint público de healthcheck."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no healthcheck', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Healthcheck retornou UP', function () {",
              "    pm.expect(json.status).to.eql('UP');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "2 - OpenAPI do Order Service via Gateway",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/orders/v3/api-docs",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "v3",
            "api-docs"
          ]
        },
        "description": "Valida que o gateway está roteando corretamente a documentação OpenAPI do order-service."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no OpenAPI do order-service', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Payload OpenAPI válido retornado', function () {",
              "    pm.expect(json.openapi).to.exist;",
              "    pm.expect(JSON.stringify(json)).to.include('/order-service/pedidos');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "3 - Login via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{login}}\",\n  \"senha\": \"{{senha}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Obtém um JWT pelo próprio gateway para acessar endpoints protegidos do actuator exposto."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no login', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('JWT retornado no login', function () {",
              "    pm.expect(json.jwt).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('jwt', json.jwt);"
            ]
          }
        }
      ]
    },
    {
      "name": "4 - Listar rotas do Gateway",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/actuator/gateway/routes",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "actuator",
            "gateway",
            "routes"
          ]
        },
        "description": "Consulta as rotas registradas no gateway para validar o mapeamento dos microsserviços."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 ao listar rotas do gateway', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const serialized = JSON.stringify(json);",
              "pm.test('Rotas do gateway retornadas', function () {",
              "    pm.expect(serialized.length).to.be.greaterThan(2);",
              "});",
              "",
              "pm.test('Rotas do order-service presentes no gateway', function () {",
              "    pm.expect(serialized).to.include('order-service');",
              "    pm.expect(serialized).to.include('/api/orders');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5 - Logout via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        },
        "description": "Finaliza a sessão ao final do fluxo de testes."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no logout', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.environment.unset('jwt');"
            ]
          }
        }
      ]
    }
  ]
}

