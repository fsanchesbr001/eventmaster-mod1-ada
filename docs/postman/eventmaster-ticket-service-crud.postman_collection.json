{
  "info": {
    "_postman_id": "db3ec6c6-d441-4d16-bbce-3a887f25ddad",
    "name": "EventMaster - Ticket Service CRUD via Gateway",
    "description": "Collection para autenticar via user-service e testar o CRUD completo do ticket-service através do API Gateway.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "jwt",
      "value": "",
      "type": "string"
    },
    {
      "key": "ticketId",
      "value": "",
      "type": "string"
    },
    {
      "key": "login",
      "value": "admin@eventmaster.com",
      "type": "string"
    },
    {
      "key": "senha",
      "value": "Senha@123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1 - Login via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"login\": \"{{login}}\",\n  \"senha\": \"{{senha}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Obtém um JWT pelo gateway para uso nas chamadas do ticket-service."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no login', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('JWT retornado no login', function () {",
              "    pm.expect(json.jwt).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.environment.set('jwt', json.jwt);",
              "pm.environment.unset('ticketId');"
            ]
          }
        }
      ]
    },
    {
      "name": "2 - Criar ingresso via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idIngresso\": 100001,\n  \"evento\": \"Show da ADA\",\n  \"data\": \"10/12/2026\",\n  \"hora\": \"20:00:00\",\n  \"tipoIngresso\": \"Inteira\",\n  \"valor\": 120.50,\n  \"nomeParticipante\": \"Fabricio Sanches\",\n  \"cpfParticipante\": \"123.456.789-00\",\n  \"situacao\": \"Disponivel\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets"
          ]
        },
        "description": "Cria um ingresso através do gateway e salva o id interno em `ticketId`."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201 ao criar ingresso', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Ingresso criado com id', function () {",
              "    pm.expect(json.id).to.exist;",
              "    pm.expect(json.idIngresso).to.eql(100001);",
              "    pm.expect(json.situacao).to.eql('Disponivel');",
              "});",
              "",
              "pm.environment.set('ticketId', json.id);"
            ]
          }
        }
      ]
    },
    {
      "name": "3 - Listar ingressos via Gateway",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tickets",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets"
          ]
        },
        "description": "Lista todos os ingressos através do gateway."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 ao listar ingressos', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Retornou lista de ingressos', function () {",
              "    pm.expect(json).to.be.an('array');",
              "    pm.expect(json.length).to.be.greaterThan(0);",
              "    pm.expect(json[0]).to.have.property('situacao');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "4 - Buscar ingresso por id via Gateway",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets",
            "{{ticketId}}"
          ]
        },
        "description": "Busca o ingresso salvo anteriormente pelo identificador interno."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 ao buscar ingresso por id', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Ingresso correto retornado', function () {",
              "    pm.expect(String(json.id)).to.eql(String(pm.environment.get('ticketId')));",
              "    pm.expect(json.evento).to.eql('Show da ADA');",
              "    pm.expect(json.situacao).to.eql('Disponivel');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "5 - Atualizar ingresso via Gateway",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"idIngresso\": 100001,\n  \"evento\": \"Peça de Teatro Premium\",\n  \"data\": \"12/12/2026\",\n  \"hora\": \"21:30:00\",\n  \"tipoIngresso\": \"Meia\",\n  \"valor\": 75.00,\n  \"nomeParticipante\": \"Fabricio Sanches\",\n  \"cpfParticipante\": \"123.456.789-00\",\n  \"situacao\": \"Reservado\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets",
            "{{ticketId}}"
          ]
        },
        "description": "Atualiza o ingresso já criado através do gateway."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 ao atualizar ingresso', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Ingresso atualizado com sucesso', function () {",
              "    pm.expect(json.evento).to.eql('Peça de Teatro Premium');",
              "    pm.expect(json.tipoIngresso).to.eql('Meia');",
              "    pm.expect(Number(json.valor)).to.eql(75);",
              "    pm.expect(json.situacao).to.eql('Reservado');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6 - Excluir ingresso via Gateway",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets",
            "{{ticketId}}"
          ]
        },
        "description": "Exclui o ingresso criado no fluxo de teste."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 204 ao excluir ingresso', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "7 - Buscar ingresso excluído via Gateway",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/tickets/{{ticketId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "tickets",
            "{{ticketId}}"
          ]
        },
        "description": "Confirma que o ingresso removido não pode mais ser consultado."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 404 após excluir ingresso', function () {",
              "    pm.response.to.have.status(404);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Erro NOT_FOUND retornado', function () {",
              "    pm.expect(json.error).to.eql('NOT_FOUND');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "8 - Logout via Gateway",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{jwt}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        },
        "description": "Finaliza a sessão ao final do fluxo de testes."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no logout', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.environment.unset('jwt');"
            ]
          }
        }
      ]
    }
  ]
}

