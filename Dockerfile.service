FROM maven:3.9.9-eclipse-temurin-21 AS builder

ARG MODULE_PATH
WORKDIR /workspace
COPY . .
RUN mvn -pl ${MODULE_PATH} -am -DskipTests package \
    && cp $(find ${MODULE_PATH}/target -maxdepth 1 -name '*.jar' ! -name '*.jar.original' | head -n 1) /tmp/app.jar

FROM eclipse-temurin:21-jre

WORKDIR /app
COPY --from=builder /tmp/app.jar /app/app.jar
ENTRYPOINT ["java", "-jar", "/app/app.jar"]

